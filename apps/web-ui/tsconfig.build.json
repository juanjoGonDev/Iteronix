{
   "extends": "./tsconfig.json",
   "compilerOptions": {
     "allowJs": true,
     "checkJs": false,
     "noEmit": false,
     "outDir": "./dist",
     "rootDir": "./src",
     "declaration": false,
     "sourceMap": true,
     "moduleResolution": "bundler",
     "allowImportingTsExtensions": false,
     "noEmitOnError": true
   },
   "include": [
     "src/**/*"
   ],
   "exclude": [
     "**/*.test.ts",
     "**/*.test.tsx",
     "node_modules"
   ]
 }
